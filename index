<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, minimum-scale=1.0, maximum-scale=1.0">
    <title>Math AR: Speedy Multiplication</title>
    
    <!-- Libraries -->
    <!-- ใช้ A-Frame 1.3.0 และ AR.js เพื่อความเสถียรบนมือถือ -->
    <script src="https://aframe.io/releases/1.3.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;700&display=swap" rel="stylesheet">

    <style>
        body { margin: 0; overflow: hidden; font-family: 'Chakra Petch', sans-serif; background-color: #080c14; }
        #ar-hud { display: none; }
        #game-over { display: none; }
        .glass-panel {
            background: rgba(17, 24, 39, 0.85);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
    </style>
</head>
<body class="text-white">

    <!-- A-Frame AR Scene -->
    <!-- เพิ่ม raycaster และชี้ให้จับเฉพาะคลาส .collidable เพื่อให้แตะจอได้แม่นยำขึ้น -->
    <a-scene embedded arjs="sourceType: webcam; debugUIEnabled: false;" vr-mode-ui="enabled: false" renderer="logarithmicDepthBuffer: true;" cursor="rayOrigin: mouse; fuse: false;" raycaster="objects: .collidable">
        
        <!-- Standard Hiro Marker -->
        <a-marker preset="hiro" id="ar-marker">
            
            <!-- Group สำหรับตัวเลือกคำตอบ ยกให้ลอยขึ้นมาและเอียงหาผู้เล่นเล็กน้อย -->
            <a-entity position="0 0.5 -1" rotation="-45 0 0" scale="1.5 1.5 1.5">
                
                <!-- ตัวเลือกด้านขวา (Right Option) -->
                <a-plane id="option_r_plane" 
                         width="1.2" height="0.8" 
                         color="#ec4899" 
                         opacity="0.9" 
                         position="1 0 0" 
                         class="collidable"
                         handler>
                    <a-text id="option_r_text"
                            value="?" 
                            align="center" 
                            color="#fff" 
                            width="4" 
                            position="0 0 0.05"></a-text>
                    <a-text value="RIGHT" 
                            align="center" 
                            color="#fff" 
                            opacity="0.5"
                            width="2" 
                            position="0 -0.3 0.05"></a-text>
                </a-plane>

                <!-- ตัวเลือกด้านซ้าย (Left Option) -->
                <a-plane id="option_l_plane" 
                         width="1.2" height="0.8" 
                         color="#3b82f6" 
                         opacity="0.9" 
                         position="-1 0 0" 
                         class="collidable"
                         handler>
                    <a-text id="option_l_text"
                            value="?" 
                            align="center" 
                            color="#fff" 
                            width="4" 
                            position="0 0 0.05"></a-text>
                    <a-text value="LEFT" 
                            align="center" 
                            color="#fff" 
                            opacity="0.5"
                            width="2" 
                            position="0 -0.3 0.05"></a-text>
                </a-plane>

            </a-entity>
        </a-marker>

        <a-entity camera></a-entity>
    </a-scene>

    <!-- HTML UI Overlay -->
    <div id="ui-container" class="absolute inset-0 pointer-events-none z-10 flex flex-col items-center p-4">
        
        <!-- Main Menu -->
        <div id="main-menu" class="glass-panel w-full max-w-lg p-6 rounded-3xl mt-10 pointer-events-auto shadow-2xl">
            <h1 class="text-4xl font-extrabold text-center mb-2 text-pink-500 tracking-tight">สูตรคูณ AR</h1>
            <p class="text-gray-300 text-center mb-6 text-sm">การจัดการเรียนรู้แบบ Active Learning<br>ฝึกสมอง แม่ 2-12 • 20 ข้อ</p>
            
            <div class="space-y-5">
                <div>
                    <label class="block text-sm font-bold text-gray-300 mb-2">ระดับความยาก</label>
                    <div class="grid grid-cols-3 gap-2">
                        <button class="menu-btn selected" data-type="diff" data-value="easy">ง่าย (2-5)</button>
                        <button class="menu-btn" data-type="diff" data-value="medium">ปานกลาง (2-9)</button>
                        <button class="menu-btn" data-type="diff" data-value="hard">ยาก (2-12)</button>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-bold text-gray-300 mb-2">เวลา (วินาที)</label>
                    <div class="grid grid-cols-3 gap-2">
                        <button class="menu-btn" data-type="time" data-value="30">30 วิ</button>
                        <button class="menu-btn selected" data-type="time" data-value="60">60 วิ</button>
                        <button class="menu-btn" data-type="time" data-value="120">120 วิ</button>
                    </div>
                </div>

                <div class="pt-4 border-t border-gray-700">
                    <button id="start-game" class="w-full bg-pink-600 hover:bg-pink-700 text-white font-bold py-3 px-6 rounded-xl text-lg transition shadow-lg active:scale-95">
                        เริ่มเล่นเกม!
                    </button>
                    <div class="text-center mt-3 text-xs text-gray-400">
                        *เตรียม <a href="https://stemkosmos.com/wp-content/uploads/2019/08/HIRO.jpg" target="_blank" class="text-blue-400 underline pointer-events-auto">Hiro Marker</a> ให้พร้อม แล้วส่องกล้องไปที่รูป
                    </div>
                </div>
            </div>
        </div>

        <!-- HUD (แสดงระหว่างเล่น) -->
        <div id="ar-hud" class="w-full max-w-md pt-2">
            <div class="flex justify-between items-center glass-panel px-5 py-2 rounded-full mb-2 border-b-2 border-pink-500 shadow-md">
                <div class="text-xs text-gray-400">คะแนน</div>
                <div class="text-3xl font-extrabold text-white tabular-nums" id="score">0</div>
                <div class="text-xs text-gray-400">เวลา</div>
                <div class="text-3xl font-extrabold text-blue-400 tabular-nums" id="time">60</div>
            </div>

            <!-- กล่องแสดงโจทย์บนจอ 2D เผื่อหลุดโฟกัสจาก Marker -->
            <div class="glass-panel w-full p-4 rounded-2xl border border-pink-700/50 text-center shadow-lg">
                <div class="flex justify-center items-center gap-2 mb-1 text-sm text-gray-400">
                    <span id="question-index">ข้อที่ 1</span> / <span>20</span>
                </div>
                <div class="text-5xl font-extrabold text-pink-400 tracking-wider" id="hud_question">? × ?</div>
                <div class="text-xs text-gray-300 mt-2 bg-gray-800/80 inline-block px-3 py-1 rounded-full">ใช้นิ้วแตะที่แผ่นป้ายคำตอบในกล้องได้เลย!</div>
            </div>
        </div>

        <!-- Game Over Screen -->
        <div id="game-over" class="glass-panel w-full max-w-md p-8 rounded-3xl mt-16 pointer-events-auto text-center shadow-2xl border-2 border-pink-600">
            <h2 class="text-5xl font-extrabold text-pink-500 mb-2">จบเกม!</h2>
            <p id="game-over-reason" class="text-gray-400 mb-6 text-lg">เวลาหมด</p>
            
            <div class="glass-panel p-4 rounded-2xl bg-gray-900/80 mb-8 border border-gray-700">
                <div class="text-gray-400 text-sm">คะแนนที่ได้</div>
                <div id="final-score" class="text-7xl font-extrabold text-white mt-1 tabular-nums">0</div>
                <div class="text-gray-300 text-base mt-2">ตอบถูก <span id="final-correct" class="font-bold text-pink-400">0</span> จาก 20 ข้อ</div>
            </div>

            <button id="restart-game" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-xl text-lg transition active:scale-95 shadow-lg">
                เล่นอีกครั้ง
            </button>
        </div>
    </div>

    <!-- Script ควบคุมปุ่มและ Tailwind -->
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        gray: { 950: '#080c14', 900: '#111827', 800: '#1f2937' },
                        pink: { 500: '#ec4899', 600: '#db2777', 700: '#be185d' },
                        blue: { 400: '#60a5fa', 600: '#2563eb', 700: '#1d4ed8' }
                    }
                }
            }
        }
    </script>

    <!-- Game Logic -->
    <script>
        let gameState = 'menu'; 
        let config = { diff: 'easy', time: '60' };
        let gameData = {
            currentQuestionIdx: 0,
            score: 0,
            correctCount: 0,
            timeRemaining: 0,
            currentCorrectAnswer: null,
            timerInterval: null,
            maxQuestions: 20
        };

        const scoreValues = { easy: 5, medium: 10, hard: 15 };

        // HTML Elements
        const uiContainer = document.getElementById('ui-container');
        const mainMenu = document.getElementById('main-menu');
        const arHud = document.getElementById('ar-hud');
        const gameOverScreen = document.getElementById('game-over');
        const scoreDisplay = document.getElementById('score');
        const timeDisplay = document.getElementById('time');
        const questionIdxDisplay = document.getElementById('question-index');
        const hudQuestionText = document.getElementById('hud_question');

        // A-Frame Elements
        const optionLPlane = document.getElementById('option_l_plane');
        const optionLText = document.getElementById('option_l_text');
        const optionRPlane = document.getElementById('option_r_plane');
        const optionRText = document.getElementById('option_r_text');

        // เมนูเลือกระดับความยากและเวลา
        document.querySelectorAll('.menu-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const type = btn.dataset.type;
                document.querySelectorAll(`.menu-btn[data-type="${type}"]`).forEach(b => {
                    b.classList.remove('selected', 'bg-blue-600', 'ring-2', 'ring-white', 'text-white');
                    b.classList.add('bg-gray-800', 'text-gray-300');
                });
                btn.classList.add('selected', 'bg-blue-600', 'ring-2', 'ring-white', 'text-white');
                btn.classList.remove('bg-gray-800', 'text-gray-300');
                config[type] = btn.dataset.value;
            });
        });

        // Setup ปุ่มเริ่มต้น
        document.querySelectorAll('.menu-btn').forEach(btn => {
            if (btn.classList.contains('selected')) {
                btn.classList.add('bg-blue-600', 'ring-2', 'ring-white', 'text-white');
            } else {
                btn.classList.add('bg-gray-800', 'text-gray-300', 'py-2', 'rounded-lg', 'text-sm');
                if(btn.classList.contains('selected')) btn.classList.add('py-2', 'rounded-lg', 'text-sm');
            }
            if(!btn.classList.contains('py-2')) btn.classList.add('py-2', 'rounded-lg', 'text-sm');
        });

        document.getElementById('start-game').addEventListener('click', startGame);
        document.getElementById('restart-game').addEventListener('click', () => location.reload());

        function startGame() {
            gameState = 'playing';
            gameData.currentQuestionIdx = 0;
            gameData.score = 0;
            gameData.correctCount = 0;
            gameData.timeRemaining = parseInt(config.time);

            mainMenu.style.display = 'none';
            arHud.style.display = 'block';
            gameOverScreen.style.display = 'none';
            uiContainer.classList.remove('pointer-events-none');

            updateHudDisplay();
            generateQuestion();
            
            gameData.timerInterval = setInterval(() => {
                gameData.timeRemaining--;
                updateHudDisplay();
                if (gameData.timeRemaining <= 0) endGame('time');
            }, 1000);
        }

        function updateHudDisplay() {
            timeDisplay.innerText = gameData.timeRemaining;
            scoreDisplay.innerText = gameData.score;
            questionIdxDisplay.innerText = `ข้อที่ ${gameData.currentQuestionIdx + 1}`;
        }

        function generateQuestion() {
            if (gameData.currentQuestionIdx >= gameData.maxQuestions) {
                endGame('complete');
                return;
            }

            let minFact = 2;
            let maxFact = 12;
            if (config.diff === 'easy') maxFact = 5;
            else if (config.diff === 'medium') maxFact = 9;

            let numA = Math.floor(Math.random() * (maxFact - minFact + 1)) + minFact;
            let numB = Math.floor(Math.random() * 11) + 2; 

            gameData.currentCorrectAnswer = numA * numB;
            hudQuestionText.innerText = `${numA} × ${numB}`;

            // สร้างคำตอบที่ผิด 1 ข้อ
            let wrongAnswer = gameData.currentCorrectAnswer + (Math.random() > 0.5 ? numA : -numA);
            if (wrongAnswer === gameData.currentCorrectAnswer || wrongAnswer <= 0) wrongAnswer += 2;

            // สุ่มซ้าย-ขวา
            const correctIsRight = Math.random() > 0.5;
            const optionL = correctIsRight ? wrongAnswer : gameData.currentCorrectAnswer;
            const optionR = correctIsRight ? gameData.currentCorrectAnswer : wrongAnswer;

            optionLText.setAttribute('value', optionL.toString());
            optionRText.setAttribute('value', optionR.toString());

            optionLPlane.dataset.correct = (!correctIsRight).toString();
            optionRPlane.dataset.correct = correctIsRight.toString();
            
            // คืนค่าสีป้ายเดิม
            optionLPlane.setAttribute('color', '#3b82f6');
            optionRPlane.setAttribute('color', '#ec4899');
        }

        // ระบบจับการทัชหน้าจอของ A-Frame
        AFRAME.registerComponent('handler', {
            init: function () {
                const el = this.el;
                el.addEventListener('mousedown', function () {
                    if (gameState !== 'playing') return;
                    
                    const isCorrect = el.dataset.correct === 'true';
                    el.setAttribute('color', isCorrect ? '#4ade80' : '#ef4444'); // เขียว=ถูก, แดง=ผิด
                    
                    if (isCorrect) {
                        gameData.score += scoreValues[config.diff];
                        gameData.correctCount++;
                    } else {
                        gameData.timeRemaining = Math.max(0, gameData.timeRemaining - 3); // ตอบผิดโดนหักเวลา 3 วิ
                    }

                    setTimeout(() => {
                        gameData.currentQuestionIdx++;
                        generateQuestion();
                        updateHudDisplay();
                    }, 400);
                });
            }
        });

        function endGame(reason) {
            clearInterval(gameData.timerInterval);
            gameState = 'gameover';
            
            arHud.style.display = 'none';
            gameOverScreen.style.display = 'block';
            uiContainer.classList.add('pointer-events-none');
            gameOverScreen.classList.add('pointer-events-auto');

            document.getElementById('game-over-reason').innerText = reason === 'complete' ? 'ทำครบ 20 ข้อแล้ว!' : 'หมดเวลา!';
            document.getElementById('final-score').innerText = gameData.score;
            document.getElementById('final-correct').innerText = gameData.correctCount;
        }
    </script>
</body>
</html>
